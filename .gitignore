# PDFs — source papers and article draft (unpublished/copyright); named explicitly,
# not by blanket *.pdf, so a future non-PDF dropped into these folders isn't silently tracked
sources/
article/
*.pdf

# Jupyter / Python cruft
.ipynb_checkpoints/
__pycache__/
*.pyc
.pytest_cache/
.DS_Store
.Rhistory

# Downloaded datasets — never committed; provenance documented in notebooks/tracker
data/

# Build artifacts
*.html
*_files/

# Third-party source material — folder-level rule, not just *.pdf (added 24 Jul 2026):
# a .txt/.png/.docx dropped here would otherwise be tracked into a public repo.
references/
